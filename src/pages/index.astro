---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import PaperEntry from '../components/PaperEntry.astro';
import PaperLinks from '../components/PaperLinks.astro';
import profile from '../data/profile.json';
import highlights from '../data/highlights.json';
import portrait from '../assets/portrait.jpg';

const research = (await getCollection('research')).sort(
  (a, b) => a.data.order - b.data.order
);
const featured = research.find((p) => p.data.featured);
const selected = research.filter((p) => !p.data.featured && p.data.selected);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.name,
  jobTitle: profile.role,
  worksFor: {
    '@type': 'Organization',
    name: 'Cambridge Judge Business School, University of Cambridge',
  },
  email: `mailto:${profile.email}`,
  url: 'https://www.atreyadey.com/',
  sameAs: [
    profile.links.scholar,
    profile.links.linkedin,
    profile.links.github,
    profile.links.institution,
  ],
};
---

<Base path="/">
  <script
    type="application/ld+json"
    set:html={JSON.stringify(personSchema)}
    slot="head"
  />

  <!-- Hero / About -->
  <section class="hero" aria-label="About me" id="about">
    <div class="hero-text">
      <h1>{profile.name}</h1>
      <p class="hero-role">
        {profile.role},
        <a href={profile.affiliations[0].url}>Cambridge Judge Business School</a>
      </p>
      <p class="hero-statement">{profile.bio}</p>
      <div class="hero-links">
        <a class="button button--solid" href="/research/">Research</a>
        <a class="button" href={profile.cv.file}>CV</a>
        <a class="button" href={profile.links.scholar}>Google Scholar</a>
        <a class="button" href={`mailto:${profile.email}`}>Email</a>
      </div>
    </div>
    <Image
      class="portrait"
      src={portrait}
      alt={`Portrait of ${profile.name}`}
      width={320}
      densities={[1, 2]}
      loading="eager"
    />
  </section>

  <!-- Recent presentations and awards -->
  <section class="section" aria-labelledby="highlights-heading">
    <h2 class="section-heading" id="highlights-heading">
      Recent presentations &amp; awards
    </h2>
    <div class="highlights">
      <div>
        <h3 class="highlights-subheading">Presentations</h3>
        <ul class="highlights-list">
          {
            highlights.presentations.map((item) => (
              <li>
                <span class="highlights-year">{item.year}</span>
                <span>{item.text}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h3 class="highlights-subheading">Awards</h3>
        <ul class="highlights-list">
          {
            highlights.awards.map((item) => (
              <li>
                <span class="highlights-year">{item.year}</span>
                <span>{item.text}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- Featured paper -->
  {
    featured && (
      <section class="section" aria-labelledby="featured-heading">
        <h2 class="section-heading" id="featured-heading">
          Featured research
        </h2>
        <article class="featured">
          <div class="featured-body">
            <h3 class="featured-title">
              <a href={`/research/${featured.id}/`}>{featured.data.title}</a>
            </h3>
            <p class="meta">
              {featured.data.status}
              {featured.data.version && ` · ${featured.data.version}`}
            </p>
            <p>{featured.data.summary}</p>
            {featured.data.awards.map((award) => (
              <p class="award">{award}</p>
            ))}
            <PaperLinks entry={featured} detailsLink={true} />
            {featured.data.abstract && (
              <details class="abstract">
                <summary>Abstract</summary>
                <p>{featured.data.abstract}</p>
              </details>
            )}
          </div>
          {featured.data.image && (
            <figure class="featured-figure">
              <a href={`/research/${featured.id}/`}>
                <Image
                  src={featured.data.image}
                  alt={featured.data.imageAlt ?? ''}
                  width={900}
                  loading="eager"
                />
              </a>
              {featured.data.imageCaption && (
                <figcaption>{featured.data.imageCaption}</figcaption>
              )}
            </figure>
          )}
        </article>
      </section>
    )
  }

  <!-- Selected research -->
  <section class="section" aria-labelledby="research-heading">
    <h2 class="section-heading" id="research-heading">Selected research</h2>
    {selected.map((entry) => <PaperEntry entry={entry} />)}
    <p class="more-link"><a href="/research/">All research →</a></p>
  </section>

  <!-- Media -->
  <section class="section" aria-labelledby="media-heading" id="media">
    <h2 class="section-heading" id="media-heading">Media</h2>
    <div class="video-frame">
      <iframe
        src="https://www.youtube-nocookie.com/embed/ZFzzNxLAWf4"
        title="PRI interview: Atreya Dey discusses rising seas and sovereign credit risk with Tom Gosling"
        loading="lazy"
        allowfullscreen
        allow="accelerometer; encrypted-media; gyroscope; picture-in-picture"
      ></iframe>
    </div>
    <p class="meta video-caption">
      Discussing "<a href="/research/rising-seas/">Inattention to the coming
      storm?</a>" with Tom Gosling (London Business School) after receiving
      the Best PhD Paper Award at the PRI Academic Network Conference 2024.
    </p>
  </section>

</Base>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2.5rem;
    padding: 3.5rem 0 3rem;
  }

  .hero-role {
    font-size: 1.05rem;
    color: var(--muted);
    margin: 0 0 1.1rem;
  }

  .hero-statement {
    max-width: 40rem;
    margin: 0 0 1.5rem;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .portrait {
    width: 15.5rem;
    height: auto;
    border-radius: 8px;
    flex-shrink: 0;
  }

  @media (max-width: 40em) {
    .hero {
      flex-direction: column-reverse;
      gap: 1.5rem;
      padding-top: 2rem;
    }

    .portrait {
      width: 10rem;
    }
  }

  .video-frame {
    position: relative;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: #000;
  }

  .video-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .video-caption {
    margin-top: 0.75rem;
  }

  .highlights {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
  }

  .highlights-subheading {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
  }

  .highlights-list {
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.92rem;
  }

  .highlights-list li {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 0.75rem;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--border);
  }

  .highlights-list li:last-child {
    border-bottom: none;
  }

  .highlights-year {
    color: var(--muted);
    font-weight: 500;
    white-space: nowrap;
  }

  @media (max-width: 40em) {
    .highlights {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  .featured {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 38%;
    gap: 1.5rem;
    align-items: center;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: #fff;
    padding: 1.4rem 1.5rem 1.6rem;
  }

  .featured-figure {
    margin: 0;
    min-width: 0;
  }

  .featured-figure img {
    display: block;
    width: 100%;
    height: auto;
  }

  .featured-figure figcaption {
    font-size: 0.8rem;
    color: var(--muted);
    margin-top: 0.6rem;
    line-height: 1.45;
  }

  .featured-body {
    min-width: 0;
  }

  @media (max-width: 48em) {
    .featured {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  .featured-title {
    font-size: 1.45rem;
    margin: 0 0 0.3rem;
  }

  .featured-title a {
    color: var(--text);
    text-decoration: none;
  }

  .featured-title a:hover {
    color: var(--accent);
  }

  .featured-body > p {
    margin: 0.6rem 0 0;
  }

  .more-link {
    margin: 1.25rem 0 0;
    font-size: 0.95rem;
  }
</style>
