---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import PaperEntry from '../components/PaperEntry.astro';
import PaperLinks from '../components/PaperLinks.astro';
import NewsList from '../components/NewsList.astro';
import profile from '../data/profile.json';
import portrait from '../assets/portrait.jpg';

const research = (await getCollection('research')).sort(
  (a, b) => a.data.order - b.data.order
);
const featured = research.find((p) => p.data.featured);
const selected = research.filter((p) => !p.data.featured && p.data.selected);

const news = (await getCollection('news'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.name,
  jobTitle: profile.role,
  worksFor: {
    '@type': 'Organization',
    name: 'Cambridge Judge Business School, University of Cambridge',
  },
  email: `mailto:${profile.email}`,
  url: 'https://www.atreyadey.com/',
  sameAs: [
    profile.links.scholar,
    profile.links.linkedin,
    profile.links.github,
    profile.links.institution,
  ],
};
---

<Base path="/">
  <script
    type="application/ld+json"
    set:html={JSON.stringify(personSchema)}
    slot="head"
  />

  <!-- Hero -->
  <section class="hero" aria-label="Introduction">
    <div class="hero-text">
      <h1>{profile.name}</h1>
      <p class="hero-role">
        {profile.role},
        <a href={profile.affiliations[0].url}>Cambridge Judge Business School</a>
      </p>
      <p class="hero-statement">{profile.heroStatement}</p>
      <div class="hero-links">
        <a class="button button--solid" href="/research/">Research</a>
        <a class="button" href={profile.cv.file}>CV</a>
        <a class="button" href={profile.links.scholar}>Google Scholar</a>
        <a class="button" href={`mailto:${profile.email}`}>Email</a>
      </div>
    </div>
    <Image
      class="portrait"
      src={portrait}
      alt={`Portrait of ${profile.name}`}
      width={320}
      densities={[1, 2]}
      loading="eager"
    />
  </section>

  <!-- Featured paper -->
  {
    featured && (
      <section class="section" aria-labelledby="featured-heading">
        <h2 class="section-heading" id="featured-heading">
          Featured research
        </h2>
        <article class="featured">
          {featured.data.image && (
            <figure>
              <a href={`/research/${featured.id}/`}>
                <Image
                  src={featured.data.image}
                  alt={featured.data.imageAlt ?? ''}
                  width={1400}
                  loading="eager"
                />
              </a>
              {featured.data.imageCaption && (
                <figcaption>{featured.data.imageCaption}</figcaption>
              )}
            </figure>
          )}
          <div class="featured-body">
            <h3 class="featured-title">
              <a href={`/research/${featured.id}/`}>{featured.data.title}</a>
            </h3>
            <p class="meta">
              {featured.data.status}
              {featured.data.version && ` · ${featured.data.version}`}
            </p>
            <p>{featured.data.summary}</p>
            {featured.data.awards.map((award) => (
              <p class="award">{award}</p>
            ))}
            <PaperLinks entry={featured} detailsLink={true} />
            {featured.data.abstract && (
              <details class="abstract">
                <summary>Abstract</summary>
                <p>{featured.data.abstract}</p>
              </details>
            )}
          </div>
        </article>
      </section>
    )
  }

  <!-- Selected research -->
  <section class="section" aria-labelledby="research-heading">
    <h2 class="section-heading" id="research-heading">Selected research</h2>
    {selected.map((entry) => <PaperEntry entry={entry} />)}
    <p class="more-link"><a href="/research/">All research →</a></p>
  </section>

  <!-- News -->
  <section class="section" aria-labelledby="news-heading">
    <h2 class="section-heading" id="news-heading">News</h2>
    <NewsList items={news} />
    <p class="more-link"><a href="/news/">All news →</a></p>
  </section>

  <!-- About -->
  <section class="section" aria-labelledby="about-heading" id="about">
    <h2 class="section-heading" id="about-heading">About</h2>
    <p>{profile.bio}</p>
    <p class="meta">
      A full academic history is in my <a href={profile.cv.file}>CV (PDF)</a>.
    </p>
  </section>
</Base>

<style>
  .hero {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2.5rem;
    padding: 3.5rem 0 3rem;
  }

  .hero-role {
    font-size: 1.05rem;
    color: var(--muted);
    margin: 0 0 1.1rem;
  }

  .hero-statement {
    max-width: 34rem;
    margin: 0 0 1.5rem;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .portrait {
    width: 160px;
    height: auto;
    border-radius: 8px;
    flex-shrink: 0;
  }

  @media (max-width: 40em) {
    .hero {
      flex-direction: column-reverse;
      gap: 1.5rem;
      padding-top: 2rem;
    }

    .portrait {
      width: 128px;
    }
  }

  .featured {
    border: 1px solid var(--border);
    border-radius: 6px;
    background: #fff;
    overflow: hidden;
  }

  .featured figure {
    margin: 0;
    background: #fff;
    border-bottom: 1px solid var(--border);
  }

  .featured figure img {
    display: block;
    width: 100%;
    height: auto;
    padding: 1.25rem 1.25rem 0.5rem;
  }

  .featured figcaption {
    font-size: 0.82rem;
    color: var(--muted);
    padding: 0 1.25rem 1rem;
  }

  .featured-body {
    padding: 1.4rem 1.5rem 1.6rem;
  }

  .featured-title {
    font-size: 1.45rem;
    margin: 0 0 0.3rem;
  }

  .featured-title a {
    color: var(--text);
    text-decoration: none;
  }

  .featured-title a:hover {
    color: var(--accent);
  }

  .featured-body > p {
    margin: 0.6rem 0 0;
  }

  .more-link {
    margin: 1.25rem 0 0;
    font-size: 0.95rem;
  }
</style>
