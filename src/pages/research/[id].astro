---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import PaperLinks from '../../components/PaperLinks.astro';

export async function getStaticPaths() {
  const research = await getCollection('research');
  return research.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const {
  title,
  authors,
  status,
  version,
  tags,
  abstract,
  awards,
  presentations,
} = entry.data;

const scholarlySchema = {
  '@context': 'https://schema.org',
  '@type': 'ScholarlyArticle',
  headline: title,
  author: authors.map((a) => ({ '@type': 'Person', name: a.name })),
  abstract: abstract,
  url: new URL(`/research/${entry.id}/`, Astro.site).toString(),
};
---

<Base
  title={title}
  description={entry.data.summary}
  path={`/research/${entry.id}/`}
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(scholarlySchema)}
    slot="head"
  />

  <article class="paper-page">
    <header>
      {
        tags.length > 0 && (
          <ul class="tags" aria-label="Research areas">
            {tags.map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>
        )
      }
      <h1>{title}</h1>
      <p class="meta">
        {
          authors.map((a, i) => (
            <>
              {a.url ? <a href={a.url}>{a.name}</a> : a.name}
              {a.affiliation && ` (${a.affiliation})`}
              {i < authors.length - 1 ? ', ' : ''}
            </>
          ))
        }
      </p>
      <p class="meta">{status}{version && ` · ${version}`}</p>
      {awards.map((award) => <p class="award">{award}</p>)}
      <PaperLinks entry={entry} />
    </header>

    {
      entry.data.image && (
        <figure class="paper-figure">
          <Image
            src={entry.data.image}
            alt={entry.data.imageAlt ?? ''}
            width={1400}
          />
          {entry.data.imageCaption && (
            <figcaption>{entry.data.imageCaption}</figcaption>
          )}
        </figure>
      )
    }

    {
      abstract && (
        <section aria-labelledby="abstract-heading" class="abstract-section">
          <h2 class="section-heading" id="abstract-heading">
            Abstract
          </h2>
          <p>{abstract}</p>
        </section>
      )
    }

    <section aria-labelledby="overview-heading" class="overview-section">
      <h2 class="section-heading" id="overview-heading">Overview</h2>
      <div class="prose">
        <Content />
      </div>
    </section>

    {
      presentations.length > 0 && (
        <section aria-labelledby="presentations-heading">
          <h2 class="section-heading" id="presentations-heading">
            Presentations
          </h2>
          <ul class="presentations">
            {presentations.map((p) => (
              <li>{p}</li>
            ))}
          </ul>
        </section>
      )
    }

    <p class="back-link"><a href="/research/">← All research</a></p>
  </article>
</Base>

<style>
  .paper-page {
    padding-top: 2.5rem;
  }

  .paper-page h1 {
    font-size: 1.7rem;
    margin-bottom: 0.5rem;
  }

  .paper-page header {
    margin-bottom: 2.25rem;
  }

  .paper-figure {
    margin: 0 0 2.25rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: #fff;
    overflow: hidden;
  }

  .paper-figure img {
    display: block;
    width: 100%;
    height: auto;
    padding: 1rem 1rem 0.5rem;
  }

  .paper-figure figcaption {
    font-size: 0.82rem;
    color: var(--muted);
    padding: 0 1rem 0.9rem;
  }

  .abstract-section,
  .overview-section {
    margin-bottom: 2.25rem;
  }

  .presentations {
    margin: 0;
    padding-left: 1.2rem;
    font-size: 0.95rem;
  }

  .presentations li {
    margin-bottom: 0.3rem;
  }

  .back-link {
    margin-top: 2.5rem;
    font-size: 0.95rem;
  }
</style>
