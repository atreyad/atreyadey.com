---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found" path="/404">
  <div class="page-intro">
    <h1>Page not found</h1>
    <p>
      The page you were looking for doesn't exist or has moved. You might be
      looking for my <a href="/research/">research</a>, <a href="/news/">news</a>,
      or <a href="/cv/">CV</a>.
    </p>
    <p><a href="/">← Back to the homepage</a></p>
  </div>
</Base>

<style>
  .page-intro {
    padding: 3rem 0;
  }
</style>
