---
import Base from '../layouts/Base.astro';
import profile from '../data/profile.json';
---

<Base
  title="CV"
  description={`Curriculum vitae of ${profile.name}.`}
  path="/cv/"
>
  <div class="page-intro">
    <h1>Curriculum vitae</h1>
    <p>
      <a class="button button--solid" href={profile.cv.file}
        >Download CV (PDF)</a
      >
    </p>
    <p class="meta">Last updated: {profile.cv.updated}</p>
  </div>

  <section class="section">
    <h2 class="section-heading">At a glance</h2>
    <dl class="glance">
      <dt>Current position</dt>
      <dd>
        {profile.role}, <a href={profile.affiliations[0].url}>Cambridge Judge
        Business School</a>, with the
        <a href={profile.affiliations[1].url}>Cambridge Endowment for Research
        in Finance</a> and <a href={profile.affiliations[2].url}>Trinity Hall</a>.
      </dd>
      <dt>Education</dt>
      <dd>
        PhD in Financial Technology, University of Edinburgh Business School
        (2025); visiting scholar, Columbia University (2024); MSc in Data
        Science, Northwestern University (2019); BA in Economics and
        Mathematics (minor), Haverford College (2015).
      </dd>
      <dt>Research fields</dt>
      <dd>{profile.researchInterests.join(' · ')}</dd>
      <dt>Previously</dt>
      <dd>
        Economist at Moody's Analytics (2015–2020); researcher with Baillie
        Gifford (summer 2025).
      </dd>
    </dl>
  </section>
</Base>

<style>
  .page-intro {
    padding: 2.5rem 0 1rem;
  }

  .page-intro .button {
    margin-top: 0.5rem;
  }

  .glance dt {
    font-weight: 600;
    font-size: 0.9rem;
    margin-top: 1.1rem;
  }

  .glance dd {
    margin: 0.2rem 0 0;
  }
</style>
