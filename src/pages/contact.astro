---
import Base from '../layouts/Base.astro';
import profile from '../data/profile.json';
---

<Base
  title="Contact"
  description={`Contact details and professional profiles for ${profile.name}.`}
  path="/contact/"
>
  <div class="page-intro">
    <h1>Contact</h1>
  </div>

  <section class="section">
    <dl class="contact-list">
      <dt>Email</dt>
      <dd><a href={`mailto:${profile.email}`}>{profile.email}</a></dd>

      <dt>Affiliations</dt>
      <dd>
        <ul class="affiliation-list">
          <li>
            <a href={profile.affiliations[0].url}>Cambridge Judge Business
            School</a>, University of Cambridge
          </li>
          <li>
            <a href={profile.affiliations[1].url}>Cambridge Endowment for
            Research in Finance</a>
          </li>
          <li>
            <a href={profile.affiliations[2].url}>Trinity Hall</a>, University
            of Cambridge
          </li>
        </ul>
      </dd>

      <dt>Profiles</dt>
      <dd>
        <ul class="link-row">
          <li><a href={profile.links.institution}>University profile</a></li>
          <li><a href={profile.links.scholar}>Google Scholar</a></li>
          <li><a href={profile.links.linkedin}>LinkedIn</a></li>
          <li><a href={profile.links.github}>GitHub</a></li>
        </ul>
      </dd>
    </dl>
    <p class="meta">
      The quickest way to reach me is by email. I am happy to share paper
      drafts and slides on request.
    </p>
  </section>
</Base>

<style>
  .page-intro {
    padding: 2.5rem 0 1rem;
  }

  .contact-list dt {
    font-weight: 600;
    font-size: 0.9rem;
    margin-top: 1.1rem;
  }

  .contact-list dd {
    margin: 0.2rem 0 0;
  }

  .affiliation-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .affiliation-list li {
    padding: 0.15rem 0;
  }

  .section .meta {
    margin-top: 2rem;
  }
</style>
