---
import { Image } from 'astro:assets';
import PaperLinks from './PaperLinks.astro';

/** A single research entry in a list (Research page and homepage). */
interface Props {
  entry: any; // CollectionEntry<'research'>
  headingLevel?: 'h2' | 'h3';
}

const { entry, headingLevel: Heading = 'h3' } = Astro.props;
const { title, authors, status, version, tags, summary, abstract, awards } =
  entry.data;
const coauthors = authors.filter((a: any) => a.name !== 'Atreya Dey');
---

<article class:list={['paper', { 'has-image': !!entry.data.image }]}>
  <div class="paper-main">
    {
      tags.length > 0 && (
        <ul class="tags" aria-label="Research areas">
          {tags.map((tag: string) => (
            <li>{tag}</li>
          ))}
        </ul>
      )
    }
    <Heading class="paper-title">
      <a href={`/research/${entry.id}/`}>{title}</a>
    </Heading>
    <p class="meta">
      {
        coauthors.length > 0 && (
          <>
            with{' '}
            {coauthors.map((a: any, i: number) => (
              <>
                {a.url ? <a href={a.url}>{a.name}</a> : a.name}
                {i < coauthors.length - 1 ? ', ' : ''}
              </>
            ))}
            {' · '}
          </>
        )
      }
      {status}{version && ` · ${version}`}
    </p>
    <p class="summary">{summary}</p>
    {awards.map((award: string) => <p class="award">{award}</p>)}
    <PaperLinks entry={entry} detailsLink={true} />
    {
      abstract && (
        <details class="abstract">
          <summary>Abstract</summary>
          <p>{abstract}</p>
        </details>
      )
    }
  </div>
  {
    entry.data.image && (
      <a
        class="paper-figure"
        href={`/research/${entry.id}/`}
        aria-hidden="true"
        tabindex="-1"
      >
        <Image
          src={entry.data.image}
          alt=""
          width={640}
          loading="lazy"
        />
      </a>
    )
  }
</article>

<style>
  .paper {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
  }

  .paper:last-child {
    border-bottom: none;
  }

  .paper.has-image {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 38%;
    gap: 1.75rem;
    align-items: center;
  }

  .paper-main {
    min-width: 0;
  }

  .paper-figure {
    display: block;
    min-width: 0;
  }

  .paper-figure img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 48em) {
    .paper.has-image {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .paper-figure {
      order: 2;
      max-width: 24rem;
    }
  }

  .paper-title {
    font-size: 1.25rem;
    margin: 0 0 0.3rem;
  }

  .paper-title a {
    color: var(--text);
    text-decoration: none;
  }

  .paper-title a:hover {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
  }

  .summary {
    margin: 0.5rem 0 0;
  }
</style>
